    "checksum": "canonical_value modulo 4 is the alternating signed trit sum, including the implicit leading one",
    "closed_charge_census": "at trit length m>=1: shrink=3^(m-1), neutral=(3^m+1)/2, grow=(3^(m-1)-1)/2",
    "dyadic_battery": "B(w)=2*len(w)+v2(canonical_value(w)+1); every growing macro has B(M(w))=B(w), so fresh space spends two units of v2 charge",
    "length_charge": "len(M(w))-len(w)=number_of_odd_sweeps-1",
    "max_trit_length": 10,
    "mean_length_delta": "under the uniform length-m word measure: -1/6 - 1/(2*3^m)",
    "recharge_table": [
      "head 0, N mod 2=0: deltaB=v2((N+1)+1)-3",
      "head 0, N mod 2=1: deltaB=-1",
      "head 1/2, N mod 4=0: deltaB=v2((N+1)+3)-4",
      "head 1/2, N mod 4=1: deltaB=v2(3*(N+1)+2)-3",
      "head 1/2, N mod 4=2: deltaB=v2((N+1)+1)-2",
      "head 1/2, N mod 4=3: deltaB=0 and 4*(N'+1)=9*(N+1)"
    ],
    "reproduction_type": "head 0 never grows; head 1 or 2 grows by one exactly when canonical_value(w)=3 (mod 4)",
